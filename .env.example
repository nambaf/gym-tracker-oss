# ─────────────────────────────────────────────────────────────────────────────
# Gym Tracker — Environment Variables
#
# Copy this file to .env.local and fill in the values.
# In production (Amplify) set variables in the Amplify console under
# "Environment variables" — they are injected at build time by amplify.yml.
# ─────────────────────────────────────────────────────────────────────────────

# === AWS ===
# Region where the stack runs (DynamoDB + Cognito).
APP_AWS_REGION=eu-south-1

# === Cognito (single-user auth) ===
# Outputs from the SAM stack after `sam deploy`.
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# === DynamoDB tables ===
# Auto-derived by amplify.yml from APP_NAME + ENVIRONMENT. Set explicitly
# only when running locally against a deployed stack.
APP_NAME=gym-tracker
ENVIRONMENT=dev
DYNAMO_TABLE_EXERCISES=
DYNAMO_TABLE_SESSIONS=
DYNAMO_TABLE_SETS=
DYNAMO_TABLE_PLANS=
DYNAMO_TABLE_SETTINGS=

# Optional: cache TTL (seconds) for the in-process data cache.
DATA_CACHE_TTL_S=600

# Optional: explicit AWS credentials for local dev. In production Amplify
# provides the IAM role automatically; leave these unset there.
# DYNAMODB_ACCESS_KEY=
# DYNAMODB_SECRET_KEY=
# DYNAMODB_SESSION_TOKEN=

# === AI Coach ===
# Allowed values: 'bedrock' | 'gemini' | 'openai' | 'anthropic' | 'off'
AI_PROVIDER=off

# --- AI_PROVIDER=bedrock ---
# Claude via AWS Bedrock. Region may differ from APP_AWS_REGION
# (Claude is not available in eu-south-1; use us-east-1, eu-central-1, us-west-2).
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5

# --- AI_PROVIDER=gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- AI_PROVIDER=openai ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- AI_PROVIDER=anthropic (direct Anthropic API, not Bedrock) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# === Localization ===
# Default UI language when the user hasn't picked one yet. 'it' | 'en'.
DEFAULT_LANG=it

# === Build ===
NODE_ENV=development
